{
  "version": "2025.11",
  "core-network-configuration": {
    "vpn-ecmp-support": false,
    "dns-support": true,
    "security-group-referencing-support": false,
    "inside-cidr-blocks": [
      "10.100.0.0/16"
    ],
    "asn-ranges": [
      "64512-64520"
    ],
    "edge-locations": [
      {
        "location": "us-east-1",
        "inside-cidr-blocks": [
          "10.100.0.0/24"
        ]
      },
      {
        "location": "eu-central-1",
        "inside-cidr-blocks": [
          "10.100.1.0/24"
        ]
      }
    ]
  },
  "segments": [
    {
      "name": "sdwan",
      "require-attachment-acceptance": false
    },
    {
      "name": "prod",
      "require-attachment-acceptance": false,
      "deny-filter": [
        "dev"
      ]
    },
    {
      "name": "dev",
      "require-attachment-acceptance": false,
      "deny-filter": [
        "prod"
      ]
    }
  ],
  "network-function-groups": [],
  "segment-actions": [
    {
      "action": "share",
      "mode": "attachment-route",
      "segment": "sdwan",
      "share-with": [
        "prod"
      ],
      "routing-policy-names": [
        "sdwantoproduction"
      ]
    },
    {
      "action": "share",
      "mode": "attachment-route",
      "segment": "sdwan",
      "share-with": [
        "dev"
      ],
      "routing-policy-names": [
        "sdwantodevelopment"
      ]
    }
  ],
  "attachment-policies": [
    {
      "rule-number": 100,
      "condition-logic": "or",
      "conditions": [
        {
          "type": "tag-value",
          "operator": "equals",
          "key": "segment",
          "value": "sdwan"
        }
      ],
      "action": {
        "association-method": "tag",
        "tag-value-of-key": "segment"
      }
    }
  ],
  "attachment-routing-policy-rules": [
    {
      "rule-number": 100,
      "description": "Apply inbound filter to sdwan Connect attachments",
      "conditions": [
        {
          "type": "routing-policy-label",
          "value": "sdwancommunityfilter"
        }
      ],
      "action": {
        "associate-routing-policies": [
          "sdwaninbounddropblocked"
        ]
      }
    }
  ],
  "routing-policies": [
    {
      "routing-policy-name": "sdwantoproduction",
      "routing-policy-description": "sdwan-to-production",
      "routing-policy-direction": "inbound",
      "routing-policy-number": 200,
      "routing-policy-rules": [
        {
          "rule-number": 100,
          "rule-definition": {
            "match-conditions": [
              {
                "type": "community-in-list",
                "value": "65001:100"
              }
            ],
            "condition-logic": "or",
            "action": {
              "type": "allow"
            }
          }
        }
      ]
    },
    {
      "routing-policy-name": "sdwantodevelopment",
      "routing-policy-description": "sdwan-to-development",
      "routing-policy-direction": "inbound",
      "routing-policy-number": 300,
      "routing-policy-rules": [
        {
          "rule-number": 100,
          "rule-definition": {
            "match-conditions": [
              {
                "type": "community-in-list",
                "value": "65001:200"
              }
            ],
            "condition-logic": "or",
            "action": {
              "type": "allow"
            }
          }
        }
      ]
    },
    {
      "routing-policy-name": "sdwaninbounddropblocked",
      "routing-policy-description": "sdwan-inbound-drop-blocked",
      "routing-policy-direction": "inbound",
      "routing-policy-number": 100,
      "routing-policy-rules": [
        {
          "rule-number": 100,
          "rule-definition": {
            "match-conditions": [
              {
                "type": "community-in-list",
                "value": "65001:999"
              }
            ],
            "condition-logic": "or",
            "action": {
              "type": "drop"
            }
          }
        },
        {
          "rule-number": 1000,
          "rule-definition": {
            "match-conditions": [
              {
                "type": "prefix-in-cidr",
                "value": "0.0.0.0/0"
              }
            ],
            "condition-logic": "or",
            "action": {
              "type": "allow"
            }
          }
        }
      ]
    }
  ]
}